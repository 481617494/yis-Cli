def draw_cli_select(idx: int) -> None:
    clear()
    put(f"{B}你想要修改什么 CLI？{R}")
    put(f"{D}← → 切换   Enter 确认   q 退出{R}")
    put()
    parts: list[str] = []
    for i, c in enumerate(CLIS):
        if i == idx:
            parts.append(f"{REV} {c['label']} {R}")
        else:
            parts.append(f" {c['label']} ")
    put("  " + "  ".join(parts))
    put()
    put(f"  当前: {CLIS[idx]['label']}")


def draw_model_list(
    cli_label: str,
    models: list[dict[str, Any]],
    current_id: str | None,
    cursor: int,
    status: str = "",
) -> None:
    clear()
    put(f"{B}{cli_label}{R}  自定义模型")
    put(f"{D}↑↓ 移动   Enter 选用/新增   e 编辑   d 删除   Esc 返回{R}")
    put()

    total = len(models) + 1
    if not models:
        put(f"{D}  (暂无模型，选最下面「+ 新增模型」){R}")
        put()

    for i in range(total):
        on = i == cursor
        if i < len(models):
            m = models[i]
            using = m.get("id") == current_id
            flag = "* " if using else "  "
            name = pad(str(m.get("name") or "未命名"), 14)
            model_s = pad(f"{m.get('provider', '')}/{m.get('model', '')}", 28)
            key_s = mask_key(str(m.get("apiKey") or ""))
            text = f"{flag}{name}  {model_s}  {key_s}"
            if on:
                put(f"  {REV}> {text}{R}")
            else:
                put(f"    {text}")
        else:
            if on:
                put(f"  {REV}> + 新增模型{R}")
            else:
                put(f"    {YELLOW}+ 新增模型{R}")

    put()
    if status:
        put(f"{GREEN}{status}{R}")


def draw_vendor_select(idx: int) -> None:
    clear()
    put(f"{B}新增模型 — 选择厂商{R}")
    put(f"{D}← → / ↑↓ 切换   Enter 下一步   Esc 取消{R}")
    put()
    for i, v in enumerate(VENDOR_PRESETS):
        if i == idx:
            put(f"  {REV}> {v['label']}{R}  {D}{v['provider']}/{v['model']}{R}")
        else:
            put(f"    {v['label']}")


def draw_pick_list(
    title: str,
    items: list[str],
    cursor: int,
    hint: str = "",
    status: str = "",
) -> None:
    clear()
    put(f"{B}{title}{R}")
    put(f"{D}↑↓ 选择   Enter 确认   m 手动输入   r 重新拉取   Esc 取消{R}")
    if hint:
        put(f"{D}{hint}{R}")
    put()
    if not items:
        put(f"{YELLOW}  (列表为空，按 m 手动输入){R}")
    else:
        # 窗口滚动，避免列表太长
        win = 12
        start = max(0, min(cursor - win // 2, max(0, len(items) - win)))
        end = min(len(items), start + win)
        if start > 0:
            put(f"{D}  … 上面还有 {start} 项{R}")
        for i in range(start, end):
            label = items[i]
            if i == cursor:
                put(f"  {REV}> {label}{R}")
            else:
                put(f"    {label}")
        if end < len(items):
            put(f"{D}  … 下面还有 {len(items) - end} 项{R}")
    put()
    if status:
        put(f"{D}{status}{R}")


# ---------------------------------------------------------------------------
# 输入 / 选择
# ---------------------------------------------------------------------------

def prompt_text(term: Term, label: str, default: str = "") -> str | None:
    term.cooked()
    show_cursor()
    try:
        put()
        if default:
            put_raw(f"{label} [{default}]: ")
        else:
            put_raw(f"{label}: ")
        try:
            line = sys.stdin.readline()
        except KeyboardInterrupt:
            return None
        if line == "":
            return None
        line = line.rstrip("\r\n")
        return line if line else (default or "")
    finally:
        hide_cursor()
        term.raw()


def pick_model_id(
    term: Term,
    provider: str,
    api_key: str,
    base_url: str = "",
    current: str = "",
    title: str = "选择模型",
) -> str | None:
    """自动拉模型列表供选择；可手动输入。"""
    clear()
    put(f"{B}正在获取模型列表…{R}")
    put(f"{D}provider={provider}{R}")
    models, note = list_models_for_provider(provider, api_key, base_url, prefer_current=current)

    cursor = 0
    if current and current in models:
        cursor = models.index(current)
    status = note

    while True:
        draw_pick_list(title, models, cursor, hint=f"当前: {current or '-'}", status=status)
        k = term.read_key()
        if k in ("esc", "q", "ctrl-c"):
            return None
        if k == "up":
            if models:
                cursor = (cursor - 1) % len(models)
        elif k == "down":
            if models:
                cursor = (cursor + 1) % len(models)
        elif k == "r":
            clear()
            put(f"{B}重新拉取…{R}")
            models, note = list_models_for_provider(
                provider, api_key, base_url, prefer_current=current
            )
            cursor = 0
            if current and current in models:
                cursor = models.index(current)
            status = note
        elif k == "m":
            manual = prompt_text(term, "模型 ID", current or "")
            if manual is None:
                continue
            manual = manual.strip()
            if manual:
                return manual
        elif k == "enter":
            if models:
                return models[cursor]
            # 空列表走手动
            manual = prompt_text(term, "模型 ID", current or "")
            if manual is None:
                return None
            manual = manual.strip()
            return manual or None


def flow_add_model(term: Term) -> dict[str, Any] | None:
    idx = 0
    while True:
        draw_vendor_select(idx)
        k = term.read_key()
        if k in ("esc", "q", "ctrl-c"):
            return None
        if k in ("left", "up"):
            idx = (idx - 1) % len(VENDOR_PRESETS)
        elif k in ("right", "down"):
            idx = (idx + 1) % len(VENDOR_PRESETS)
        elif k == "enter":
            break

    preset = VENDOR_PRESETS[idx]
    provider = str(preset["provider"])
    default_base = str(preset.get("baseURL") or "")

    clear()
    put(f"{B}新增模型 — {preset['label']}{R}")
    put(f"{D}直接回车用默认值，Ctrl+C 取消{R}")

    name = prompt_text(term, "显示名称", str(preset["label"]))
    if name is None:
        return None
    api_key = prompt_text(term, "API Key", "")
    if api_key is None or not str(api_key).strip():
        clear()
        put(f"{YELLOW}API Key 不能为空，已取消{R}")
        time.sleep(1.0)
        return None
    api_key = str(api_key).strip()

    base_url = default_base
    if provider in ("openai", "anthropic", "custom") or not default_base:
        bu = prompt_text(term, "Base URL（可空）", default_base)
        if bu is None:
            return None
        base_url = bu.strip()

    mid = pick_model_id(
        term,
        provider=provider,
        api_key=api_key,
        base_url=base_url,
        current=str(preset.get("model") or ""),
        title=f"选择模型 — {preset['label']}",
    )
    if mid is None:
        return None

    return {
        "id": uuid.uuid4().hex[:12],
        "name": name.strip() or str(preset["label"]),
        "provider": provider,
        "model": mid.strip(),
        "apiKey": api_key,
        "baseURL": base_url,
        "format": "anthropic" if provider == "anthropic" else "openai",
        "key": f"{provider}/{mid.strip()}",
    }


def flow_edit_model(term: Term, entry: dict[str, Any]) -> dict[str, Any] | None:
    """编辑显示名称 / API Key / 模型（可自动拉列表）。"""
    clear()
    put(f"{B}编辑模型{R}")
    put(f"{D}{entry.get('name')}  ({entry.get('provider')}/{entry.get('model')}){R}")
    put(f"{D}直接回车保留原值，Ctrl+C 取消{R}")

    name = prompt_text(term, "显示名称", str(entry.get("name") or ""))
    if name is None:
        return None

    old_key = str(entry.get("apiKey") or "")
    api_in = prompt_text(
        term,
        f"API Key（回车保留 {mask_key(old_key)}）",
        "",
    )
    if api_in is None:
        return None
    api_key = api_in.strip() if api_in.strip() else old_key
    if not api_key:
        clear()
        put(f"{YELLOW}API Key 不能为空{R}")
        time.sleep(1.0)
        return None

    base_url = str(entry.get("baseURL") or DEFAULT_BASE_URLS.get(str(entry.get("provider") or ""), ""))
    provider = str(entry.get("provider") or "custom")
    if provider in ("openai", "anthropic", "custom"):
        bu = prompt_text(term, "Base URL", base_url)
        if bu is None:
            return None
        base_url = bu.strip()

    mid = pick_model_id(
        term,
        provider=provider,
        api_key=api_key,
        base_url=base_url,
        current=str(entry.get("model") or ""),
        title=f"选择模型 — {name or entry.get('name')}",
    )
    if mid is None:
        return None

    updated = dict(entry)
    updated["name"] = name.strip() or str(entry.get("name") or "未命名")
    updated["apiKey"] = api_key
    updated["model"] = mid.strip()
    updated["baseURL"] = base_url
    updated["key"] = f"{provider}/{mid.strip()}"
    return updated


# ---------------------------------------------------------------------------
# 主交互
# ---------------------------------------------------------------------------

def main() -> int:
    if not sys.stdin.isatty():
        print("请在交互式终端运行: qoder-switch", file=sys.stderr)
        return 1

    store = ensure_store()
    hide_cursor()
    try:
        with Term() as term:
            while True:
                # -------- 屏1：选 CLI（左右）--------
                cli_idx = 0
                while True:
                    draw_cli_select(cli_idx)
                    k = term.read_key()
                    if k in ("q", "esc", "ctrl-c"):
                        clear()
                        return 0
                    if k == "left":
                        cli_idx = (cli_idx - 1) % len(CLIS)
                    elif k == "right":
                        cli_idx = (cli_idx + 1) % len(CLIS)
                    elif k == "enter":
                        break

                cli = CLIS[cli_idx]
                cli_id = cli["id"]
                bucket = bucket_of(store, cli_id)
                models: list[dict[str, Any]] = list(bucket.get("models") or [])
                current_id: str | None = bucket.get("current")
                cursor = 0
                if current_id:
                    for i, m in enumerate(models):
                        if m.get("id") == current_id:
                            cursor = i
                            break
                status = ""

                # -------- 屏2：模型列表 --------
                while True:
                    draw_model_list(cli["label"], models, current_id, cursor, status)
                    status = ""
                    k = term.read_key()
                    n_items = len(models) + 1

                    if k in ("esc", "q"):
                        break  # 回 CLI 选择
                    if k == "ctrl-c":
                        clear()
                        return 0
                    if k == "up":
                        cursor = (cursor - 1) % n_items
                    elif k == "down":
                        cursor = (cursor + 1) % n_items
                    elif k == "d":
                        if cursor < len(models):
                            target = models[cursor]
                            if target.get("id") == current_id:
                                status = "不能删除正在使用的模型，请先切换到其他项"
                            else:
                                models = [m for m in models if m.get("id") != target.get("id")]
                                bucket["models"] = models
                                store["clis"][cli_id] = bucket
                                save_store(store)
                                cursor = min(cursor, len(models))
                                status = f"已删除：{target.get('name')}"
                        else:
                            status = "「新增模型」不可删除"
                    elif k == "e":
                        if cursor >= len(models):
                            status = "请先选中已有模型再编辑"
                            continue
                        target = models[cursor]
                        updated = flow_edit_model(term, target)
                        if not updated:
                            status = "已取消编辑"
                            continue
                        # 写回列表
                        for i, m in enumerate(models):
                            if m.get("id") == target.get("id"):
                                models[i] = updated
                                break
                        bucket["models"] = models
                        store["clis"][cli_id] = bucket
                        save_store(store)
                        status = f"已保存：{updated.get('name')}"
                        # 若是当前使用中的模型，自动重新 apply
                        if updated.get("id") == current_id:
                            msg = apply_model(cli_id, updated)
                            status = f"{status}  ·  {msg}  ·  请重启 CLI"
                    elif k == "enter":
                        if cursor >= len(models):
                            # 新增
                            entry = flow_add_model(term)
                            if entry:
                                models.append(entry)
                                bucket["models"] = models
                                store["clis"][cli_id] = bucket
                                save_store(store)
                                cursor = len(models) - 1
                                status = f"已添加：{entry['name']}  ·  再按 Enter 设为使用"
                        else:
                            chosen = models[cursor]
                            if not str(chosen.get("apiKey") or "").strip():
                                status = "该模型没有 API Key"
                                continue
                            msg = apply_model(cli_id, chosen)
                            bucket["current"] = chosen.get("id")
                            current_id = str(chosen.get("id"))
                            store["clis"][cli_id] = bucket
                            save_store(store)
                            status = msg + "  ·  请重启该 CLI 后生效"
    finally:
        show_cursor()
        clear()
        put("已退出")


if __name__ == "__main__":
    raise SystemExit(main())
