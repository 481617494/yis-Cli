def backup_file(path: Path) -> None:
    if not path.exists():
        return
    ts = time.strftime("%Y%m%d-%H%M%S")
    shutil.copy2(path, BACKUPS_DIR / f"{path.name}.{ts}.bak")
    backups = sorted(BACKUPS_DIR.glob(f"{path.name}.*.bak"), reverse=True)
    for old in backups[20:]:
        try:
            old.unlink()
        except OSError:
            pass


def normalize_openai_base(url: str) -> str:
    """
    规范化 OpenAI 兼容 baseURL。

    注意：Qoder 云端代理往往会自己拼 `/v1/chat/completions`。
    若这里再写死 `.../v1`，可能变成 `.../v1/v1/chat/completions` 导致 provider_error。
    因此对常见根域名只保留 host 根路径；用户若已带 /v1 则去掉末尾 /v1。
    """
    u = (url or "").strip().rstrip("/")
    if not u:
        return ""
    if u.endswith("/models"):
        u = u[: -len("/models")].rstrip("/")
    # 去掉末尾 /v1，交给 Qoder 侧拼接
    if u.endswith("/v1"):
        u = u[: -len("/v1")]
    return u


def looks_like_reasoning_model(model_id: str) -> bool:
    m = (model_id or "").lower()
    return any(
        x in m
        for x in (
            "reasoner",
            "reasoning",
            "thinking",
            "v4-pro",
            "v4-flash",
            "-r1",
            "o1",
            "o3",
            "o4",
        )
    )


def to_qoder_custom_item(model: dict[str, Any]) -> dict[str, Any]:
    """
    转成 Qoder settings 里的 customModels 项。

    重要：Qoder CLI 对非 custom 的 provider 会丢掉 baseURL，改走云端白名单池。
    自备 Key 直连厂商时必须用 provider=custom + baseURL，否则会报
    custom model config not found。
    """
    raw_provider = str(model.get("provider") or "custom").strip() or "custom"
    mid = str(model.get("model") or "model").strip()
    api_key = str(model.get("apiKey") or "").strip()
    display = str(model.get("name") or mid)
    fmt = str(
        model.get("format")
        or ("anthropic" if raw_provider == "anthropic" else "openai")
    ).strip()

    base = str(model.get("baseURL") or "").strip()
    if not base:
        base = DEFAULT_BASE_URLS.get(raw_provider, "")

    # 有明确 API 地址 → 走 custom 直连（自备 Key）
    # anthropic 兼容中转同样需要 url
    if base or raw_provider in ("custom", "openai", "anthropic"):
        if fmt == "openai" and base:
            base = normalize_openai_base(base)
        # anthropic 一般不带 /v1
        write_provider = "custom"
        # key 必须与 provider 一致，避免沿用 deepseek/xxx 导致云端池查找
        key = f"custom/{mid}"
        item: dict[str, Any] = {
            "provider": write_provider,
            "model": mid,
            "apiKey": api_key,
            "key": key,
            "displayName": display,
            "format": fmt,
        }
        if base:
            item["baseURL"] = base
        # DeepSeek v4 / reasoner 等是推理模型，需标记否则上游响应可能被判错
        if model.get("isReasoning") is True or looks_like_reasoning_model(mid):
            item["isReasoning"] = True
        if model.get("isVl") is True:
            item["isVl"] = True
        return item

    # 无 baseURL：保留命名 provider，走 Qoder 官方 BYOK 池（Coding Plan 等）
    key = str(model.get("key") or f"{raw_provider}/{mid}")
    return {
        "provider": raw_provider,
        "model": mid,
        "apiKey": api_key,
        "key": key,
        "displayName": display,
        "format": fmt,
    }


def apply_qoder(model: dict[str, Any]) -> str:
    backup_file(QODER_SETTINGS)
    qs: dict[str, Any] = {}
    if QODER_SETTINGS.exists():
        try:
            raw = json.loads(QODER_SETTINGS.read_text(encoding="utf-8"))
            if isinstance(raw, dict):
                qs = raw
        except json.JSONDecodeError:
            pass

    api_key = str(model.get("apiKey") or "").strip()
    if not api_key:
        return "失败：没有 API Key"

    item = to_qoder_custom_item(model)
    key = str(item["key"])
    display = str(item.get("displayName") or key)

    mc = qs.get("modelConfigs") if isinstance(qs.get("modelConfigs"), dict) else {}
    customs = list(mc.get("customModels") or []) if isinstance(mc.get("customModels"), list) else []
    # 去掉同 key，以及旧的 provider/model 同名项
    mid = str(item.get("model") or "")
    merged = [item]
    for c in customs:
        if not isinstance(c, dict):
            continue
        ck = c.get("key") or f"{c.get('provider')}/{c.get('model')}"
        if ck == key:
            continue
        # 清理明显坏掉的配置
        if c.get("model") == mid and c.get("provider") in (item.get("provider"), model.get("provider")):
            continue
        merged.append(c)
    mc["customModels"] = merged
    qs["modelConfigs"] = mc

    mcfg = dict(qs["model"]) if isinstance(qs.get("model"), dict) else {}
    mcfg["name"] = key
    qs["model"] = mcfg

    QODER_SETTINGS.parent.mkdir(parents=True, exist_ok=True)
    QODER_SETTINGS.write_text(json.dumps(qs, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")

    QODER_MODEL_DEFAULT.parent.mkdir(parents=True, exist_ok=True)
    cache: dict[str, Any] = {"key": key, "scene": "assistant", "updatedAt": int(time.time() * 1000)}
    if QODER_MODEL_DEFAULT.exists():
        try:
            old = json.loads(QODER_MODEL_DEFAULT.read_text(encoding="utf-8"))
            if isinstance(old, dict) and old.get("uid"):
                cache["uid"] = old["uid"]
        except json.JSONDecodeError:
            pass
    QODER_MODEL_DEFAULT.write_text(json.dumps(cache, ensure_ascii=False) + "\n", encoding="utf-8")

    mode = "直连 API" if item.get("provider") == "custom" else "Qoder BYOK 池"
    base = item.get("baseURL") or ""
    return f"已启用 → Qoder CLI：{display}  [{mode}{(' · ' + base) if base else ''}]"


def apply_claude(model: dict[str, Any]) -> str:
    path = Path.home() / ".claude" / "settings.json"
    backup_file(path)
    data: dict[str, Any] = {}
    if path.exists():
        try:
            raw = json.loads(path.read_text(encoding="utf-8"))
            if isinstance(raw, dict):
                data = raw
        except json.JSONDecodeError:
            pass
    env = dict(data["env"]) if isinstance(data.get("env"), dict) else {}
    key = str(model.get("apiKey") or "")
    if key:
        env["ANTHROPIC_AUTH_TOKEN"] = key
        env["ANTHROPIC_API_KEY"] = key
    if model.get("baseURL"):
        env["ANTHROPIC_BASE_URL"] = str(model["baseURL"])
    mid = str(model.get("model") or "")
    if mid:
        env["ANTHROPIC_MODEL"] = mid
        for k in (
            "ANTHROPIC_DEFAULT_SONNET_MODEL",
            "ANTHROPIC_DEFAULT_OPUS_MODEL",
            "ANTHROPIC_DEFAULT_HAIKU_MODEL",
        ):
            env[k] = mid
    data["env"] = env
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    return f"已启用 → Claude Code：{model.get('name')}"


def apply_codex(model: dict[str, Any]) -> str:
    APP_HOME.mkdir(parents=True, exist_ok=True)
    sidecar = APP_HOME / "codex-active.json"
    sidecar.write_text(json.dumps(model, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    env_file = APP_HOME / "codex.env"
    lines = [f"export OPENAI_API_KEY={json.dumps(model.get('apiKey') or '')}"]
    if model.get("baseURL"):
        lines.append(f"export OPENAI_BASE_URL={json.dumps(model['baseURL'])}")
    if model.get("model"):
        lines.append(f"export OPENAI_MODEL={json.dumps(model['model'])}")
    env_file.write_text("\n".join(lines) + "\n", encoding="utf-8")
    return f"已启用 → Codex：{model.get('name')}（env: {env_file}）"


def apply_model(cli_id: str, model: dict[str, Any]) -> str:
    if cli_id == "qoder":
        return apply_qoder(model)
    if cli_id == "claude":
        return apply_claude(model)
    if cli_id == "codex":
        return apply_codex(model)
    return "未知 CLI"


def mask_key(k: str) -> str:
    if not k:
        return "未配置"
    if len(k) <= 8:
        return "****"
    return k[:3] + "****" + k[-4:]


