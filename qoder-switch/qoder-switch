def _models_urls(provider: str, base_url: str) -> list[str]:
    """候选 /models 地址。"""
    base = (base_url or DEFAULT_BASE_URLS.get(provider) or "").rstrip("/")
    if not base:
        return []
    urls: list[str] = []
    if base.endswith("/models"):
        urls.append(base)
    else:
        urls.append(f"{base}/models")
        if not base.endswith("/v1"):
            urls.append(f"{base}/v1/models")
    # 去重保序
    seen: set[str] = set()
    out: list[str] = []
    for u in urls:
        if u not in seen:
            seen.add(u)
            out.append(u)
    return out


def fetch_remote_models(provider: str, api_key: str, base_url: str = "") -> tuple[list[str], str]:
    """
    尝试从厂商 OpenAI 兼容接口拉模型列表。
    返回 (ids, 来源说明)。失败则 ([], 错误信息)。
    """
    key = (api_key or "").strip()
    if not key:
        return [], "无 API Key"

    headers_variants: list[dict[str, str]] = [
        {"Authorization": f"Bearer {key}", "Content-Type": "application/json"},
        {
            "Authorization": f"Bearer {key}",
            "Content-Type": "application/json",
            "x-api-key": key,
        },
    ]
    # 智谱部分接口用 Authorization
    if provider == "anthropic":
        headers_variants.insert(
            0,
            {
                "x-api-key": key,
                "anthropic-version": "2023-06-01",
                "Content-Type": "application/json",
            },
        )

    last_err = "无法获取"
    for url in _models_urls(provider, base_url):
        for headers in headers_variants:
            try:
                req = urllib.request.Request(url, headers=headers, method="GET")
                with urllib.request.urlopen(req, timeout=12) as resp:
                    raw = resp.read().decode("utf-8", errors="replace")
                data = json.loads(raw)
                ids: list[str] = []
                if isinstance(data, dict):
                    items = data.get("data") or data.get("models") or []
                    if isinstance(items, list):
                        for it in items:
                            if isinstance(it, str):
                                ids.append(it)
                            elif isinstance(it, dict):
                                mid = it.get("id") or it.get("name") or it.get("model")
                                if mid:
                                    ids.append(str(mid))
                elif isinstance(data, list):
                    for it in data:
                        if isinstance(it, str):
                            ids.append(it)
                        elif isinstance(it, dict) and it.get("id"):
                            ids.append(str(it["id"]))
                # 去重
                uniq: list[str] = []
                seen: set[str] = set()
                for m in ids:
                    if m not in seen:
                        seen.add(m)
                        uniq.append(m)
                if uniq:
                    return uniq, f"接口: {url}"
                last_err = f"{url} 返回空列表"
            except urllib.error.HTTPError as e:
                last_err = f"{url} HTTP {e.code}"
            except urllib.error.URLError as e:
                last_err = f"{url} 网络错误: {e.reason}"
            except Exception as e:  # noqa: BLE001
                last_err = f"{url} {type(e).__name__}: {e}"
    return [], last_err


def list_models_for_provider(
    provider: str,
    api_key: str,
    base_url: str = "",
    prefer_current: str = "",
) -> tuple[list[str], str]:
    """优先远程拉取，失败用内置 fallback。"""
    remote, src = fetch_remote_models(provider, api_key, base_url)
    if remote:
        models = list(remote)
        note = f"已获取 {len(models)} 个模型（{src}）"
    else:
        models = list(FALLBACK_MODELS.get(provider) or [])
        note = f"远程失败（{src}），使用内置列表"
        if not models:
            note = f"远程失败（{src}），无内置列表，请手动输入"

    if prefer_current and prefer_current not in models:
        models.insert(0, prefer_current)
    return models, note


