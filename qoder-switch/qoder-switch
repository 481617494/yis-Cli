def ensure_store() -> dict[str, Any]:
    APP_HOME.mkdir(parents=True, exist_ok=True)
    BACKUPS_DIR.mkdir(parents=True, exist_ok=True)
    if STORE_FILE.exists():
        try:
            data = json.loads(STORE_FILE.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            data = {"version": 1, "clis": {}}
    else:
        data = {"version": 1, "clis": {}}
    if not isinstance(data, dict):
        data = {"version": 1, "clis": {}}
    data.setdefault("clis", {})
    for c in CLIS:
        data["clis"].setdefault(c["id"], {"models": [], "current": None})
        bucket = data["clis"][c["id"]]
        if not isinstance(bucket.get("models"), list):
            bucket["models"] = []
    if not STORE_FILE.exists():
        save_store(data)
    return data


def save_store(data: dict[str, Any]) -> None:
    APP_HOME.mkdir(parents=True, exist_ok=True)
    tmp = STORE_FILE.with_suffix(".tmp")
    tmp.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    os.replace(tmp, STORE_FILE)
    try:
        os.chmod(STORE_FILE, 0o600)
    except OSError:
        pass


def bucket_of(store: dict[str, Any], cli_id: str) -> dict[str, Any]:
    return store["clis"].setdefault(cli_id, {"models": [], "current": None})


