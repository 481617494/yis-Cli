class Term:
    def __init__(self) -> None:
        self.fd = sys.stdin.fileno()
        self.old: list[Any] | None = None

    def __enter__(self) -> "Term":
        self.old = termios.tcgetattr(self.fd)
        tty.setraw(self.fd)
        return self

    def __exit__(self, *args: Any) -> None:
        if self.old is not None:
            termios.tcsetattr(self.fd, termios.TCSADRAIN, self.old)

    def raw(self) -> None:
        tty.setraw(self.fd)

    def cooked(self) -> None:
        if self.old is not None:
            termios.tcsetattr(self.fd, termios.TCSADRAIN, self.old)

    def read_key(self) -> str:
        ch = os.read(self.fd, 1)
        if ch == b"\x1b":
            rest = b""
            if select.select([self.fd], [], [], 0.05)[0]:
                rest += os.read(self.fd, 1)
            if rest.startswith(b"[") and select.select([self.fd], [], [], 0.05)[0]:
                rest += os.read(self.fd, 1)
            seq = ch + rest
            return {
                b"\x1b[A": "up",
                b"\x1b[B": "down",
                b"\x1b[C": "right",
                b"\x1b[D": "left",
            }.get(seq, "esc")
        if ch in (b"\r", b"\n"):
            return "enter"
        if ch == b"\x03":
            return "ctrl-c"
        if ch == b"q":
            return "q"
        if ch == b"d":
            return "d"
        if ch == b"e":
            return "e"
        if ch == b"m":
            return "m"
        if ch == b"r":
            return "r"
        try:
            return ch.decode("utf-8", errors="ignore")
        except Exception:
            return ""


def clear() -> None:
    sys.stdout.write("\033[2J\033[H")
    sys.stdout.flush()


def hide_cursor() -> None:
    sys.stdout.write("\033[?25l")
    sys.stdout.flush()


def show_cursor() -> None:
    sys.stdout.write("\033[?25h")
    sys.stdout.flush()


def put(s: str = "") -> None:
    # raw 模式下 \n 只下移不回列首，必须用 \r\n，否则界面会呈楼梯状
    sys.stdout.write(s + "\r\n")
    sys.stdout.flush()


def put_raw(s: str) -> None:
    sys.stdout.write(s)
    sys.stdout.flush()


def pad(s: str, width: int) -> str:
    """左对齐补空格（按字符数，够用即可）。"""
    n = len(s)
    if n >= width:
        return s[:width]
    return s + " " * (width - n)


